---
import { siteConfig } from "../config";

const { awards, metrics, softSkills } = siteConfig.achievements;
---

<section
  id="achievements"
  aria-label="Achievements and Recognition"
  class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50"
>
  <div>
    <!-- Section Header -->
    <div class="mb-12">
      <h2 class="text-3xl sm:text-4xl md:text-4xl xl:text-5xl font-bold text-gray-900">
        Achievements
      </h2>
      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>
    </div>

    <!-- Impact Metrics -->
    <div class="mb-14">
      <h3 class="text-lg font-semibold text-gray-500 uppercase tracking-widest mb-6">
        Key Impact Metrics
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {metrics.map((m) => (
          <div
            class="bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all text-center border border-gray-100"
          >
            <div
              class="text-3xl sm:text-4xl font-bold mb-1"
              style={`color: ${siteConfig.accentColor}`}
            >
              {m.value}
            </div>
            <div class="text-xs sm:text-sm text-gray-500 leading-snug">{m.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- Awards -->
      <div>
        <h3 class="text-lg font-semibold text-gray-500 uppercase tracking-widest mb-6">
          Awards & Recognition
        </h3>
        <div class="space-y-5">
          {awards.map((award) => (
            <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-all border border-gray-100">
              <div class="flex items-start gap-3">
                <div
                  class="mt-1 w-3 h-3 rounded-full flex-shrink-0"
                  style={`background-color: ${siteConfig.accentColor}`}
                ></div>
                <div>
                  <h4 class="font-semibold text-gray-900 text-base mb-1">{award.title}</h4>
                  <p class="text-gray-600 text-sm leading-relaxed">{award.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Soft Skills -->
      <div>
        <h3 class="text-lg font-semibold text-gray-500 uppercase tracking-widest mb-6">
          Core Competencies
        </h3>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <ul class="space-y-3">
            {softSkills.map((skill) => (
              <li class="flex items-center gap-3 text-gray-700 text-sm sm:text-base">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4 flex-shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke={siteConfig.accentColor}
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M5 12l5 5l10 -10" />
                </svg>
                {skill}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
